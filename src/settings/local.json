{
  "aws_region": "us-east-1",
  "dynamodb_table": "spg-api-keys",
  "log_group": "/six-sense/api",
  "api_version": "v1",
  "terraform_state_bucket": "six-sense-terraform-state",
  "terraform_lock_table": "six-sense-terraform-locks",
  "tiers": {
    "free": 500,
    "pro": 50000,
    "business": 500000,
    "enterprise": -1
  },
  "compliance_profiles": {
    "NIST": {
      "min_length": 15,
      "require_uppercase": true,
      "require_lowercase": true,
      "require_numbers": true,
      "require_symbols": true,
      "exclude_ambiguous": true
    },
    "SOC2": {
      "min_length": 12,
      "require_uppercase": true,
      "require_lowercase": true,
      "require_numbers": true,
      "require_symbols": false,
      "exclude_ambiguous": true
    },
    "strong": {
      "min_length": 8,
      "require_uppercase": false,
      "require_lowercase": false,
      "require_numbers": false,
      "require_symbols": false,
      "exclude_ambiguous": false
    }
  }
}
