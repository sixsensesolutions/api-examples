        "body": {
          "mode": "raw",
          "raw": "{\n  \"length\": 20,\n  \"quantity\": 1,\n  \"options\": {\n    \"uppercase\": true,\n    \"lowercase\": true,\n    \"numbers\": true,\n    \"symbols\": true,\n    \"exclude_ambiguous\": true\n  },\n  \"compliance\": \"strong\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 401', function () {",
              "  pm.response.to.have.status(401);",
              "});",
              "const json = pm.response.json();",
              "pm.test('error is MISSING_AUTH', function () {",
              "  pm.expect(json.error).to.eql('MISSING_AUTH');",
              "});"
            ]
          }
        }
