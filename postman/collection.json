        "description": "Verifies unauthenticated requests are rejected with MISSING_AUTH.",
        "url": {
          "raw": "{{base_url}}/v1/generate",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "v1",
            "generate"
