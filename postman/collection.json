{
  "info": {
    "name": "Six Sense Solutions API",
    "_postman_id": "2d2f4bbf-ef57-4d58-b15a-e37407d95aa2",
    "description": "Postman tests for the Six Sense Solutions password generation API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Test 1 - Happy path",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{api_key}}"
          }
        ],
        "description": "Verifies successful generation with NIST profile and validates core response shape.",
        "url": {
          "raw": "{{base_url}}/v1/generate",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "v1",
            "generate"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"length\": 20,\n  \"quantity\": 5,\n  \"options\": {\n    \"uppercase\": true,\n    \"lowercase\": true,\n    \"numbers\": true,\n    \"symbols\": true,\n    \"exclude_ambiguous\": true\n  },\n  \"compliance\": \"NIST\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('passwords length is 5', function () {",
              "  pm.expect(json.passwords).to.be.an('array').with.lengthOf(5);",
              "});",
              "pm.test('every password length is 20', function () {",
              "  json.passwords.forEach(function (p) { pm.expect(p.length).to.eql(20); });",
              "});",
              "pm.test('meta.entropy_bits is a number greater than 0', function () {",
              "  pm.expect(json.meta.entropy_bits).to.be.a('number').and.to.be.above(0);",
              "});",
              "pm.test('meta.generated_at is valid ISO string', function () {",
              "  const iso = new Date(json.meta.generated_at).toISOString();",
              "  pm.expect(iso).to.eql(json.meta.generated_at);",
              "});",
              "pm.test('meta.calls_remaining is a number', function () {",
              "  pm.expect(json.meta.calls_remaining).to.be.a('number');",
              "});",
              "pm.test('meta.compliance_profile is NIST', function () {",
              "  pm.expect(json.meta.compliance_profile).to.eql('NIST');",
              "});"
            ]
          }
        }
      ]
    },
    {
