    {
      "name": "Test 9 - Rate limit hit (manual prerequisite)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer test_free_key"
          }
        ],
        "description": "Manual verification test. Requires test_free_key to already have 500 calls logged. Verifies RATE_LIMIT_EXCEEDED and calls_remaining = 0.",
        "url": {
          "raw": "{{base_url}}/v1/generate",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "v1",
            "generate"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"length\": 20,\n  \"quantity\": 1,\n  \"options\": {\n    \"uppercase\": true,\n    \"lowercase\": true,\n    \"numbers\": true,\n    \"symbols\": false,\n    \"exclude_ambiguous\": false\n  },\n  \"compliance\": \"strong\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 429', function () {",
              "  pm.response.to.have.status(429);",
              "});",
              "const json = pm.response.json();",
              "pm.test('error is RATE_LIMIT_EXCEEDED', function () {",
              "  pm.expect(json.error).to.eql('RATE_LIMIT_EXCEEDED');",
              "});",
              "pm.test('calls_remaining is 0', function () {",
              "  const remaining = json.meta && typeof json.meta.calls_remaining !== 'undefined' ? json.meta.calls_remaining : json.calls_remaining;",
              "  pm.expect(remaining).to.eql(0);",
              "});"
            ]
          }
        }
      ]
    },
